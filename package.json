{
  "name": "prosemirror-splittable",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.0",
  "description": "Inherit ProseMirror node attributes when splitting nodes.",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/prosemirror-splittable#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/prosemirror-splittable.git"
  },
  "bugs": "https://github.com/ocavue/prosemirror-splittable/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "pnpm run lint:eslint && pnpm run lint:oxfmt && pnpm run lint:knip",
    "lint:oxfmt": "oxfmt --check",
    "lint:eslint": "eslint",
    "lint:knip": "knip",
    "fix": "pnpm run fix:oxfmt && pnpm run fix:eslint",
    "fix:oxfmt": "oxfmt",
    "fix:eslint": "eslint --fix",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "prosemirror-model": "^1.21.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "prosemirror-model": {
      "optional": true
    },
    "prosemirror-state": {
      "optional": true
    },
    "prosemirror-transform": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.8.1",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.0",
    "ist": "^1.1.7",
    "knip": "^6.14.2",
    "oxfmt": "^0.53.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-test-builder": "^1.1.1",
    "prosemirror-transform": "^1.12.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
